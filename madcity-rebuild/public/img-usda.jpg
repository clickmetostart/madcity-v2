		<style id="wp-custom-css">
			





.header-navigation .header-menu-container ul ul li.menu-item > a:hover
{  border-radius: 10px;}


.header-navigation .header-menu-container ul ul.sub-menu, .header-navigation .header-menu-container ul ul.submenu 
{
    border-radius: 10px;
}


.header-navigation.header-navigation-dropdown-animation-fade-down ul ul.sub-menu, .header-navigation.header-navigation-dropdown-animation-fade-down ul ul.submenu 
{ border-radius: 10px; }


.header-html { width: 200px; }


#cookie-law-info-bar 
{border-radius: 30px;}




/* Ширина вертикальной полосы прокрутки */
::-webkit-scrollbar {
  width: 7px; 
}

/* Трек (фон под бегунком) */
::-webkit-scrollbar-track {
  background: white; 
  border-radius: 30px; 
}

/* Бегунок (ползунок) */
::-webkit-scrollbar-thumb {
  background: black; 
  border-radius: 30px; 
  height: 5px;              
}




/* header setting */
.site-header-row {
    background: white;
    margin-top: 15px;
    padding: 5px 20px 5px 20px;
    border-radius: 30px;

}






.single-content h1.elementor-heading-title, .single-content h2.elementor-heading-title, .single-content h3.elementor-heading-title, .single-content h4.elementor-heading-title, .single-content h5.elementor-heading-title, .single-content h6.elementor-heading-title {
  margin-top: 0;
  margin-bottom: 0em;  
}







.single-content p:last-child
{
  word-wrap: break-word;
  word-break: break-word;
  hyphens: auto;
	
}


@media only screen and (max-width: 767px) {
.elementor-testimonial--mobile-align-left .elementor-testimonial {
	
        display: flex;
        text-align: left;
        flex-direction: column-reverse;
        justify-content: center;
        align-items: center;
    }
}



@media (max-width: 767px) {
    .elementor-2511 .elementor-element.elementor-element-fbb3215 .elementor-testimonial__text {
        padding-top: 20px;
    }
}


@media (max-width: 767px) {
    .elementor-2511 .elementor-element.elementor-element-fbb3215 .elementor-testimonial__text 
	{text-align: center;}
}






/* кастоная кнопка на форме начало  */

/* Обёртка поля файла */
.elementor-field-group-field_0ecba3d {
    background-color: white;
    display: flex;
    border-radius: 30px;
    padding: 10px;
    position: relative;
    flex-direction: row;
    flex-wrap: nowrap;
    align-content: center;
    justify-content: flex-start;
    align-items: center;
}

/* Стилизованная псевдокнопка */
.elementor-field-group-field_0ecba3d::before {
    content: "Attach your resume.";
    width: 40%;
    text-align: center;
    display: inline-block;
    padding: 5px;
    color: white;
    border-radius: 30px;
    cursor: pointer;
    background: #f15a3d;
    transition: all 0.3s ease;
    z-index: 1;
}

/* Скрытый input[type="file"] */
.elementor-field-group-field_0ecba3d input[type="file"] {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    z-index: 2;
}

/* Отображение выбранного файла */
.elementor-field-group-field_0ecba3d .file-status {
    margin-left: 10px;
    text-align: left;
    display: block;
    color: black;
    font-size: 0.9em;
}

/* Hover эффект */
.elementor-field-group-field_0ecba3d:hover::before {
    background-color: black;
    transform: translateY(-1px);
}

/* Focus эффект */
.elementor-field-group-field_0ecba3d:focus-within::before {
    box-shadow: 0 0 0 3px rgba(191, 29, 56, 0.3);
}

/* Active состояние */
.elementor-field-group-field_0ecba3d:active::before {
    transform: translateY(1px);
}
/* кастоная кнопка на форме конец */






/* Container styles for reviews */
.ti-widget.ti-goog .ti-reviews-container .ti-reviews-container-wrapper {
    margin: 0 !important;
    margin-bottom: -8px !important;
    display: grid;
    grid-template-columns: 1fr;
    grid-gap: 10px;
}

/* Hide reviews after the 9th one */
.ti-widget.ti-goog .ti-reviews-container .ti-review-item:nth-child(n+10) {
    display: none;
}

/* Force review items to full width */
.ti-widget.ti-goog .ti-col-4 .ti-review-item {
    max-width: 100% !important;
}

/* Styles for tablets (2 columns) */
@media (min-width: 768px) and (max-width: 991px) {
    .ti-widget.ti-goog .ti-reviews-container .ti-reviews-container-wrapper {
        grid-template-columns: repeat(2, 1fr);
    }
    .ti-widget.ti-goog .ti-col-2 .ti-review-item {
        max-width: 100% !important;
    }
}

/* Styles for devices between 619px and 767px */
@media (min-width: 619px) and (max-width: 767px) {
    .ti-widget.ti-goog .ti-col-2 .ti-review-item {
        max-width: 100% !important;
    }
}

/* Styles for laptops (3 columns) */
@media (min-width: 992px) {
    .ti-widget.ti-goog .ti-reviews-container .ti-reviews-container-wrapper {
        grid-template-columns: repeat(3, 1fr);
    }
    /* Add rule for laptops (1024px) */
    .ti-widget.ti-goog .ti-col-3 .ti-review-item {
        max-width: 100% !important;
    }
}



		</style>
		</head>

